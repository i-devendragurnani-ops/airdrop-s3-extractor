{
  "name": "airdrop-s3-test-artifacts-snap-in",
  "version": "1.0.0",
  "description": "S3 Test Artifacts AirSync snap-in – test execution reports as custom objects",
  "main": "./dist/index.js",
  "scripts": {
    "build": "rimraf ./dist && tsc",
    "clean": "rm -rf dist build.tar.gz",
    "prepackage": "npm run build",
    "package": "tar -cvzf build.tar.gz dist package.json package-lock.json .npmrc",
    "start": "ts-node ./src/main.ts",
    "test-local": "npm run build && node dist/test-runner/test-runner.js"
  },
  "keywords": ["devrev", "airdrop", "s3", "test-artifacts"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@devrev/ts-adaas": "1.13.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^18.13.0",
    "rimraf": "^4.1.2",
    "ts-node": "^10.9.1",
    "tsx": "^4.7.0",
    "typescript": "^4.9.5"
  }
}
